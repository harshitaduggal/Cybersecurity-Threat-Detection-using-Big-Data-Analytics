from google.colab import drive
drive.mount('/content/drive')

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
import glob

files = glob.glob("/content/drive/MyDrive/cyber/*.csv")
data=pd.concat([pd.read_csv(file) for file in files], ignore_index=True)
data.head()

print(data.shape)
print(data.columns)

data[' Label'].value_counts().plot(kind='bar')
plt.show()

data.info()
data.isnull().sum().sort_values(ascending=False).head(10)

for col in data.columns:
  if data[col].nunique== 1:
    print(col)

data = data.drop(columns=['Fwd Header Length.1'], errors='ignore')
bulk_cols = [
    ' Fwd Avg Bytes/Bulk',
    ' Fwd Avg Packets/Bulk',
    ' Fwd Avg Bulk Rate',
    ' Bwd Avg Bytes/Bulk',
    ' Bwd Avg Packets/Bulk',
    ' Bwd Avg Bulk Rate'
    ' Destination Port'
]
data = data.drop(columns=bulk_cols, errors='ignore')
print(data.shape)

data.replace([np.inf, -np.inf], np.nan, inplace=True)
data= data.dropna()

def map_labels(label):
    if label == 'BENIGN':
        return 'Benign'
    elif 'DoS' in label or 'DDoS' in label:
        return 'DDoS'
    elif 'PortScan' in label:
        return 'PortScan'
    elif 'Brute Force' in label:
        return 'BruteForce'
    elif 'Bot' in label:
        return 'Botnet'
    elif 'Web Attack' in label:
        return 'WebAttack'
    else:
        return 'Other'
data[' Label'] = data[' Label'].apply(map_labels)
data[' Label'].value_counts()

data[' Label'].value_counts().plot(kind='bar')
plt.xticks(rotation=45)
plt.show()


