sample_data= data.sample(10000)
profile= ProfileReport(sample_data, explorative=True)
profile.to_notebook_iframe

data[' Label'].value_counts().plot(kind='bar')

corr = data.drop(' Label', axis=1).corr()
plt.figure(figsize=(10,8))
sns.heatmap(corr, cmap='coolwarm')
plt.show()

corr = data.drop(' Label', axis=1).corr().abs()

upper = corr.where(
    np.triu(np.ones(corr.shape), k=1).astype(bool)
)

to_drop = [col for col in upper.columns if any(upper[col] > 0.95)]

data = data.drop(columns=to_drop)

sns.boxplot(x=' Label', y='Flow Bytes/s', data=data.sample(5000))
plt.xticks(rotation=45)
plt.show()

sns.boxplot(x=' Label', y=' Flow Packets/s', data=data.sample(5000))
plt.xticks(rotation=45)
plt.show()

sns.boxplot(x=' Label', y=' Packet Length Mean', data=data.sample(5000))
plt.xticks(rotation=45)
plt.show()

sns.histplot(data['Flow Bytes/s'], bins=50, kde=True)
plt.title("Flow Bytes/s Distribution")
plt.show()

data['Flow Bytes/s'] = np.log1p(data['Flow Bytes/s'])

#The distribution of Flow Bytes/s is highly skewed with extreme outliers. A log transformation was applied to stabilize variance and improve model performance

sns.histplot(data['Flow Bytes/s'], bins=50, kde=True)
plt.title("Log Transformed Flow Bytes/s")
plt.show()

